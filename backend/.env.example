# Environment name used by the API at startup.
DAYFORA_ENV=development

# Backend-only values needed in later milestones. Do not copy any of these into
# the mobile application.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional hybrid semantic retrieval. Deploy supabase/functions/embed-diary-text
# and apply the diary hybrid migration before enabling this in an environment.
DAYFORA_SEMANTIC_SEARCH=false
DAYFORA_EMBEDDING_FUNCTION=embed-diary-text
OPENAI_API_KEY=
LANGGRAPH_DATABASE_URL=
# Optional for IPv4-only local networks. Use the Supavisor host/port shown in
# Supabase Dashboard → Connect, for example aws-0-<region>.pooler.supabase.com
# and 5432 (session) or 6543 (transaction).
LANGGRAPH_SUPABASE_POOLER_HOST=
LANGGRAPH_SUPABASE_POOLER_PORT=5432
DAYFORA_JOB_TOKEN=
